---
---

<section class="hero" aria-label="Абрамова Ольга, социальный психолог и антрополог">
  <video
    class="hero__video"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    poster="/images/hero-poster.jpg"
  >
    <source src="/video/hero-intro.mp4" type="video/mp4" />
  </video>

  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="hero__content">
    <h1 class="hero__name">
      <span class="hero__reveal" style="--i:0">Абрамова</span>
      <span class="hero__reveal" style="--i:1">Ольга</span>
    </h1>
    <p class="hero__role hero__reveal" style="--i:2">
      Социальный психолог и антрополог НИУ ВШЭ
    </p>
    <p class="hero__credentials hero__reveal" style="--i:3">
      Канд. псих. наук и PhD в организационной психологии: НИУ ВШЭ
    </p>

    <nav class="hero__fork hero__reveal" style="--i:4" aria-label="Выберите направление">
      <a class="hero__fork-link" href="/business">
        <span>Решения для бизнеса</span>
      </a>
      <a class="hero__fork-link hero__fork-link--ghost" href="/personal">
        <span>Программы для себя</span>
      </a>
    </nav>
  </div>
</section>

<script>
  const video = document.querySelector<HTMLVideoElement>('.hero__video');
  const hero = document.querySelector<HTMLElement>('.hero');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  function syncMotionPreference() {
    if (!video) return;
    if (prefersReducedMotion.matches) {
      video.removeAttribute('autoplay');
      video.pause();
      video.currentTime = 0;
    } else {
      video.play().catch(() => {
        /* Autoplay can be rejected by the browser; the poster frame still renders. */
      });
    }
  }

  syncMotionPreference();
  prefersReducedMotion.addEventListener('change', syncMotionPreference);

  if (video && hero && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (prefersReducedMotion.matches) continue;
          if (entry.isIntersecting) {
            video.play().catch(() => {});
          } else {
            video.pause();
          }
        }
      },
      { threshold: 0.1 }
    );
    observer.observe(hero);
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    isolation: isolate;
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    z-index: var(--z-base);
  }

  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: var(--z-scrim);
    pointer-events: none;
    background: linear-gradient(
      105deg,
      var(--color-bg) 0%,
      color-mix(in oklab, var(--color-bg) 88%, transparent) 28%,
      color-mix(in oklab, var(--color-bg) 45%, transparent) 46%,
      transparent 64%
    );
  }

  .hero__content {
    position: relative;
    z-index: var(--z-content);
    width: 100%;
    max-width: 40rem;
    display: flex;
    flex-direction: column;
    padding: clamp(1.5rem, 5vw, 4rem) clamp(1.25rem, 6vw, 5rem) clamp(3.5rem, 9vw, 6rem);
  }

  .hero__name {
    margin: 0;
    display: flex;
    flex-direction: column;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(2.75rem, 8vw, 5rem);
    line-height: 0.96;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    text-wrap: balance;
  }

  .hero__role {
    margin: 1rem 0 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.0625rem, 2.4vw, 1.375rem);
    line-height: 1.3;
    color: var(--color-ink);
    text-wrap: pretty;
  }

  .hero__credentials {
    margin: 0.5rem 0 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(0.875rem, 1.6vw, 1rem);
    line-height: 1.5;
    color: color-mix(in oklab, var(--color-ink) 75%, transparent);
    max-width: 38ch;
  }

  .hero__fork {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(0.75rem, 2vw, 1.25rem);
    margin-top: clamp(1.75rem, 4vw, 2.5rem);
  }

  .hero__fork-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(0.9375rem, 1.8vw, 1.0625rem);
    color: var(--color-bg);
    background: var(--color-ink);
    padding: 0.95rem 1.75rem;
    border-radius: 2px;
    transition: color 220ms var(--ease-out-quart), background-color 220ms var(--ease-out-quart),
      box-shadow 220ms var(--ease-out-quart), transform 220ms var(--ease-out-quart);
  }

  .hero__fork-link--ghost {
    color: var(--color-ink);
    background: color-mix(in oklab, var(--color-bg) 70%, transparent);
    box-shadow: inset 0 0 0 1.5px var(--color-ink);
  }

  .hero__fork-link:hover,
  .hero__fork-link:focus-visible {
    color: var(--color-ink);
    background: var(--color-accent);
    box-shadow: inset 0 0 0 1.5px var(--color-accent);
    transform: translateY(-2px);
  }

  .hero__fork-link:focus-visible {
    outline: none;
  }

  .hero__reveal {
    opacity: 0;
    transform: translateY(0.75rem);
    animation: hero-reveal 700ms var(--ease-out-quart) forwards;
    animation-delay: calc(var(--i, 0) * 110ms + 200ms);
  }

  @keyframes hero-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .hero__fork-link {
      transition: none;
    }
  }

  @media (max-width: 640px) {
    .hero__scrim {
      background: linear-gradient(
        180deg,
        color-mix(in oklab, var(--color-bg) 35%, transparent) 0%,
        var(--color-bg) 62%,
        var(--color-bg) 100%
      );
    }

    .hero__content {
      max-width: none;
    }

    .hero__fork {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__fork-link {
      justify-content: center;
    }
  }
</style>
