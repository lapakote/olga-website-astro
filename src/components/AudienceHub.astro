---
interface Item {
  title: string;
  description: string;
  href?: string;
  external?: boolean;
  badge?: string;
}

interface Props {
  heading: string;
  lead: string;
  items: Item[];
}

const { heading, lead, items } = Astro.props;
---

<section class="audience-hub" aria-labelledby="audience-hub-heading">
  <div class="audience-hub__inner">
    <h1 id="audience-hub-heading" class="audience-hub__heading reveal" style="--i:0">{heading}</h1>
    <p class="audience-hub__lead reveal" style="--i:1">{lead}</p>

    <ul class="audience-hub__list">
      {
        items.map((item, index) => {
          const Tag = item.href ? 'a' : 'div';
          const linkProps = item.href
            ? {
                href: item.href,
                ...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}),
              }
            : {};
          return (
            <li class="audience-hub__item reveal" style={`--i:${index + 2}`}>
              <Tag class="audience-hub__item-inner" {...linkProps}>
                <div class="audience-hub__item-text">
                  <p class="audience-hub__item-title">
                    {item.title}
                    {item.badge && <span class="audience-hub__badge">{item.badge}</span>}
                  </p>
                  <p class="audience-hub__item-description">{item.description}</p>
                </div>
                {item.href && (
                  <span class="audience-hub__arrow" aria-hidden="true">
                    {item.external ? '↗' : '→'}
                  </span>
                )}
              </Tag>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<style>
  .audience-hub {
    background: var(--color-bg);
    padding: clamp(4rem, 9vw, 7rem) clamp(1.25rem, 6vw, 5rem) clamp(4.5rem, 10vw, 7rem);
  }

  .audience-hub__inner {
    max-width: 64rem;
    margin: 0 auto;
  }

  .audience-hub__heading {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }

  .audience-hub__lead {
    margin: 0 0 clamp(2rem, 5vw, 3rem);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    color: color-mix(in oklab, var(--color-ink) 78%, transparent);
    max-width: 50ch;
  }

  .audience-hub__list {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid color-mix(in oklab, var(--color-ink) 18%, transparent);
  }

  .audience-hub__item {
    border-bottom: 1px solid color-mix(in oklab, var(--color-ink) 18%, transparent);
  }

  .audience-hub__item-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: clamp(1.25rem, 3vw, 1.75rem) 0;
    text-decoration: none;
    color: inherit;
  }

  a.audience-hub__item-inner {
    transition: padding-left 220ms var(--ease-out-quart);
  }

  a.audience-hub__item-inner:hover,
  a.audience-hub__item-inner:focus-visible {
    padding-left: 0.5rem;
  }

  a.audience-hub__item-inner:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  .audience-hub__item-text {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .audience-hub__item-title {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.125rem, 2.2vw, 1.375rem);
    color: var(--color-ink);
  }

  .audience-hub__badge {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.75rem;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: 2px;
    padding: 0.1rem 0.5rem;
  }

  .audience-hub__item-description {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.9375rem;
    color: color-mix(in oklab, var(--color-ink) 70%, transparent);
    max-width: 50ch;
  }

  .audience-hub__arrow {
    flex: 0 0 auto;
    font-size: 1.25rem;
    color: var(--color-ink);
    transition: color 220ms var(--ease-out-quart), transform 220ms var(--ease-out-quart);
  }

  a.audience-hub__item-inner:hover .audience-hub__arrow,
  a.audience-hub__item-inner:focus-visible .audience-hub__arrow {
    color: var(--color-accent);
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    a.audience-hub__item-inner,
    .audience-hub__arrow {
      transition: none;
    }
  }
</style>
