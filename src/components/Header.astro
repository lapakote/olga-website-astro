---
const navLinks = [
  { href: '/#about', label: 'Обо мне' },
  { href: '/#offers', label: 'Направления' },
  { href: '/#events', label: 'Мероприятия' },
  { href: '/#press', label: 'Статьи' },
];

const forkLinks = [
  { href: '/business', label: 'Бизнесу' },
  { href: '/personal', label: 'Для себя' },
];
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__brand">Абрамова Ольга</a>

    <nav class="site-header__nav" aria-label="Основная навигация">
      {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>

    <div class="site-header__fork">
      {forkLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </div>

    <a class="site-header__contact" href="/#contact">Контакты</a>

    <details class="site-header__mobile">
      <summary class="site-header__mobile-toggle" aria-label="Открыть меню">
        <span class="site-header__burger" aria-hidden="true">
          <span></span>
          <span></span>
        </span>
      </summary>
      <nav class="site-header__mobile-nav" aria-label="Мобильная навигация">
        {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
        {forkLinks.map((link) => <a href={link.href}>{link.label}</a>)}
        <a href="/#contact">Контакты</a>
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: var(--color-bg);
    border-bottom: 1px solid color-mix(in oklab, var(--color-ink) 12%, transparent);
  }

  .site-header__inner {
    max-width: 84rem;
    margin: 0 auto;
    padding: 0.9rem clamp(1.25rem, 6vw, 5rem);
    display: flex;
    align-items: center;
    gap: clamp(1.25rem, 3vw, 2rem);
  }

  .site-header__brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-ink);
    text-decoration: none;
    white-space: nowrap;
  }

  .site-header__nav {
    display: none;
    align-items: center;
    gap: clamp(1rem, 2vw, 1.75rem);
    margin-right: auto;
  }

  .site-header__nav a {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.875rem;
    color: color-mix(in oklab, var(--color-ink) 78%, transparent);
    text-decoration: none;
    transition: color 180ms var(--ease-out-quart);
  }

  .site-header__nav a:hover,
  .site-header__nav a:focus-visible {
    color: var(--color-ink);
  }

  .site-header__fork {
    display: none;
    align-items: center;
    gap: 0.625rem;
  }

  .site-header__fork a {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.8125rem;
    color: var(--color-ink);
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: 2px;
    box-shadow: inset 0 0 0 1.5px color-mix(in oklab, var(--color-ink) 30%, transparent);
    transition: color 180ms var(--ease-out-quart), box-shadow 180ms var(--ease-out-quart);
  }

  .site-header__fork a:hover,
  .site-header__fork a:focus-visible {
    color: var(--color-accent);
    box-shadow: inset 0 0 0 1.5px var(--color-accent);
  }

  .site-header__contact {
    display: none;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.8125rem;
    color: var(--color-bg);
    background: var(--color-ink);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: 2px;
    transition: background-color 180ms var(--ease-out-quart);
  }

  .site-header__contact:hover,
  .site-header__contact:focus-visible {
    background: var(--color-accent);
    color: var(--color-ink);
  }

  /* Mobile disclosure menu: native <details>, no JS required. */
  .site-header__mobile {
    margin-left: auto;
    position: relative;
  }

  .site-header__mobile-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    cursor: pointer;
    list-style: none;
  }

  .site-header__mobile-toggle::-webkit-details-marker {
    display: none;
  }

  .site-header__mobile-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .site-header__burger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 1.25rem;
  }

  .site-header__burger span {
    display: block;
    height: 1.5px;
    background: var(--color-ink);
    transition: transform 220ms var(--ease-out-quart), opacity 220ms var(--ease-out-quart);
  }

  .site-header__mobile[open] .site-header__burger span:first-child {
    transform: translateY(3.25px) rotate(45deg);
  }

  .site-header__mobile[open] .site-header__burger span:last-child {
    transform: translateY(-3.25px) rotate(-45deg);
  }

  .site-header__mobile-nav {
    position: absolute;
    top: calc(100% + 0.75rem);
    right: 0;
    display: flex;
    flex-direction: column;
    min-width: 14rem;
    background: var(--color-bg);
    box-shadow: 0 8px 24px color-mix(in oklab, var(--color-ink) 18%, transparent);
    border-radius: 2px;
    padding: 0.5rem;
  }

  .site-header__mobile-nav a {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-ink);
    text-decoration: none;
    padding: 0.75rem 0.75rem;
    border-radius: 2px;
    transition: background-color 180ms var(--ease-out-quart);
  }

  .site-header__mobile-nav a:hover,
  .site-header__mobile-nav a:focus-visible {
    background: var(--color-mist);
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header__burger span {
      transition: none;
    }
  }

  @media (min-width: 1000px) {
    .site-header__nav,
    .site-header__fork,
    .site-header__contact {
      display: flex;
    }

    .site-header__mobile {
      display: none;
    }
  }
</style>
