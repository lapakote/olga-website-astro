---
import { Image } from 'astro:assets';
import offerSpeaking from '../assets/images/offer-speaking.jpg';
import offerCourses from '../assets/images/offer-courses.jpg';
import offerConsulting from '../assets/images/offer-consulting.jpg';
import offerCoaching from '../assets/images/offer-coaching.jpg';

interface Offer {
  id: string;
  label: string;
  tags: string[];
  headline: string;
  body: string;
  image: ImageMetadata;
  imageAlt: string;
  imageWidth: number;
  imageHeight: number;
  link?: { href: string; label: string };
}

const offers: Offer[] = [
  {
    id: 'speaking',
    label: 'Спикерство',
    tags: ['Выступления', 'Лидерство и инновации', 'Психология удачи'],
    headline: 'Темы, которые заставляют действовать',
    body:
      'Последние данные из мира науки и кейсы лидеров вместо общих рассуждений со сцены. Топ-темы в харизматичном научпопе, упакованные так, чтобы зал слушал и применял.',
    image: offerSpeaking,
    imageAlt: 'Ольга Абрамова на сцене панельной дискуссии',
    imageWidth: 1280,
    imageHeight: 852,
    link: { href: '/topics', label: 'Смотреть темы' },
  },
  {
    id: 'courses',
    label: 'Курсы',
    tags: ['Апгрейд ваших курсов', 'Готовые курсы под бизнес', 'Рецензия и пересборка программ'],
    headline: 'Курсы, которые учат побеждать',
    body:
      'Превращаю обучающие программы в научно обоснованные продукты: от рецензии готового курса до разработки нового на стыке психологии, антропологии, IT и бизнеса.',
    image: offerCourses,
    imageAlt: 'Ольга Абрамова читает лекцию студентам',
    imageWidth: 1242,
    imageHeight: 828,
  },
  {
    id: 'consulting',
    label: 'Консалтинг',
    tags: ['Стратегические сессии', 'Научный эдвайзинг (CSO)', 'Исследования перед решениями'],
    headline: 'Консалтинг, который просчитывает',
    body:
      'Лучшее решение для сложных бизнес-ситуаций строится на данных, а не на интуиции. Стратегические сессии, исследования и научное сопровождение лидерства превращают хаос в стратегию.',
    image: offerConsulting,
    imageAlt: 'Ольга Абрамова, портрет',
    imageWidth: 960,
    imageHeight: 868,
  },
  {
    id: 'coaching',
    label: 'Коучинг',
    tags: ['Life-коучинг', 'Бизнес-коучинг', 'Метод научного скаффолдинга'],
    headline: 'Новый стандарт коучинга',
    body:
      'Метод научного скаффолдинга соединяет обучение, консультирование и практики осознанности. Апгрейд жизни или команды за 8–10 сессий: выход из кризиса, психология удачи, масштабирование мышления.',
    image: offerCoaching,
    imageAlt: 'Ольга Абрамова выступает на конференции по психологии коучинга',
    imageWidth: 1280,
    imageHeight: 960,
  },
];
---

<section class="offers" id="offers" aria-label="Направления работы">
  {
    offers.map((offer, index) => (
      <article class={`offers__row ${index % 2 === 1 ? 'offers__row--alt' : ''}`} id={offer.id}>
        <div class="offers__label-wrap">
          <h3 class="offers__label reveal" style="--i:0">
            {offer.label}
          </h3>
        </div>

        <div class="offers__body-row">
          <figure
            class="offers__media photo-tinted reveal"
            style={`--i:1; aspect-ratio: ${offer.imageWidth} / ${offer.imageHeight}`}
          >
            <Image src={offer.image} alt={offer.imageAlt} width={offer.imageWidth} height={offer.imageHeight} loading="lazy" />
          </figure>

          <div class="offers__content">
            <ul class="offers__tags reveal" style="--i:2">
              {offer.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
            <p class="offers__headline reveal" style="--i:3">
              {offer.headline}
            </p>
            <p class="offers__body reveal" style="--i:4">
              {offer.body}
            </p>
            {offer.link && (
              <a class="offers__link reveal" style="--i:5" href={offer.link.href}>
                {offer.link.label}
                <span aria-hidden="true">→</span>
              </a>
            )}
          </div>
        </div>
      </article>
    ))
  }
</section>

<style>
  .offers__row {
    background: var(--color-bg);
    padding: clamp(3rem, 8vw, 6rem) 0;
  }

  .offers__row--alt {
    background: var(--color-mist);
  }

  .offers__label-wrap {
    max-width: 78rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 6vw, 5rem);
  }

  .offers__label {
    margin: 0 0 clamp(1.75rem, 4vw, 2.5rem);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--color-ink);
  }

  .offers__body-row {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 4vw, 2.5rem);
  }

  /* Full-bleed photo: aspect-ratio comes from the real source image per offer
     (set inline), so object-fit: cover only ever trims a sliver regardless of
     whether the source is a wide panel shot or a narrow portrait. */
  .offers__media {
    margin: 0;
    width: 100%;
  }

  .offers__content {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 3vw, 1.5rem);
    min-width: 0;
    max-width: 46rem;
    padding: 0 clamp(1.25rem, 6vw, 5rem);
  }

  .offers__tags {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .offers__tags li {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.8125rem;
    color: var(--color-ink);
    background: color-mix(in oklab, var(--color-bg) 70%, transparent);
    padding: 0.4rem 0.75rem;
    border-radius: 2px;
  }

  .offers__row--alt .offers__tags li {
    background: color-mix(in oklab, var(--color-ink) 8%, var(--color-mist));
  }

  .offers__headline {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    line-height: 1.25;
    color: var(--color-ink);
    text-wrap: pretty;
  }

  .offers__body {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.6;
    color: color-mix(in oklab, var(--color-ink) 78%, transparent);
    max-width: 60ch;
  }

  .offers__link {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    align-self: flex-start;
    margin-top: 0.25rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-bg);
    background: var(--color-ink);
    padding: 0.85rem 1.5rem;
    border-radius: 2px;
    text-decoration: none;
    transition: background-color 220ms var(--ease-out-quart), color 220ms var(--ease-out-quart),
      transform 220ms var(--ease-out-quart);
  }

  .offers__link span {
    transition: transform 220ms var(--ease-out-quart);
  }

  .offers__link:hover,
  .offers__link:focus-visible {
    background: var(--color-accent);
    color: var(--color-ink);
    transform: translateY(-2px);
  }

  .offers__link:hover span,
  .offers__link:focus-visible span {
    transform: translateX(3px);
  }

  .offers__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .offers__link,
    .offers__link span {
      transition: none;
    }
  }

  @media (min-width: 768px) {
    .offers__body-row {
      flex-direction: row;
      align-items: stretch;
    }

    .offers__row--alt .offers__body-row {
      flex-direction: row-reverse;
    }

    .offers__media {
      flex: 0 0 auto;
      width: auto;
      height: clamp(18rem, 32vw, 28rem);
    }

    .offers__content {
      flex: 1 1 auto;
      justify-content: center;
    }
  }
</style>
