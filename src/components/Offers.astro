---
interface Offer {
  id: string;
  label: string;
  tags: string[];
  headline: string;
  body: string;
}

const offers: Offer[] = [
  {
    id: 'speaking',
    label: 'Спикерство',
    tags: ['Выступления', 'Лидерство и инновации', 'Психология удачи'],
    headline: 'Темы, которые заставляют действовать',
    body:
      'Последние данные из мира науки и кейсы лидеров вместо общих рассуждений со сцены. Топ-темы в харизматичном научпопе, упакованные так, чтобы зал слушал и применял.',
  },
  {
    id: 'courses',
    label: 'Курсы',
    tags: ['Апгрейд ваших курсов', 'Готовые курсы под бизнес', 'Рецензия и пересборка программ'],
    headline: 'Курсы, которые учат побеждать',
    body:
      'Превращаю обучающие программы в научно обоснованные продукты: от рецензии готового курса до разработки нового на стыке психологии, антропологии, IT и бизнеса.',
  },
  {
    id: 'consulting',
    label: 'Консалтинг',
    tags: ['Стратегические сессии', 'Научный эдвайзинг (CSO)', 'Исследования перед решениями'],
    headline: 'Консалтинг, который просчитывает',
    body:
      'Лучшее решение для сложных бизнес-ситуаций строится на данных, а не на интуиции. Стратегические сессии, исследования и научное сопровождение лидерства превращают хаос в стратегию.',
  },
  {
    id: 'coaching',
    label: 'Коучинг',
    tags: ['Life-коучинг', 'Бизнес-коучинг', 'Метод научного скаффолдинга'],
    headline: 'Новый стандарт коучинга',
    body:
      'Метод научного скаффолдинга соединяет обучение, консультирование и практики осознанности. Апгрейд жизни или команды за 8–10 сессий: выход из кризиса, психология удачи, масштабирование мышления.',
  },
];
---

<section class="offers" aria-label="Направления работы">
  {
    offers.map((offer, index) => (
      <article class={`offers__row ${index % 2 === 1 ? 'offers__row--alt' : ''}`} id={offer.id}>
        <div class="offers__inner">
          <h3 class="offers__label reveal" style="--i:0">
            {offer.label}
          </h3>

          <div class="offers__content">
            <ul class="offers__tags reveal" style="--i:1">
              {offer.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
            <p class="offers__headline reveal" style="--i:2">
              {offer.headline}
            </p>
            <p class="offers__body reveal" style="--i:3">
              {offer.body}
            </p>
          </div>
        </div>
      </article>
    ))
  }
</section>

<style>
  .offers__row {
    background: var(--color-bg);
    padding: clamp(3rem, 8vw, 6rem) clamp(1.25rem, 6vw, 5rem);
  }

  .offers__row--alt {
    background: var(--color-mist);
  }

  .offers__inner {
    max-width: 78rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 4vw, 2.5rem);
  }

  .offers__label {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--color-ink);
  }

  .offers__content {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 3vw, 1.5rem);
    max-width: 46rem;
  }

  .offers__tags {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .offers__tags li {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.8125rem;
    color: var(--color-ink);
    background: color-mix(in oklab, var(--color-bg) 70%, transparent);
    padding: 0.4rem 0.75rem;
    border-radius: 2px;
  }

  .offers__row--alt .offers__tags li {
    background: color-mix(in oklab, var(--color-ink) 8%, var(--color-mist));
  }

  .offers__headline {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    line-height: 1.25;
    color: var(--color-ink);
    text-wrap: pretty;
  }

  .offers__body {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.6;
    color: color-mix(in oklab, var(--color-ink) 78%, transparent);
    max-width: 60ch;
  }

  @media (min-width: 1024px) {
    .offers__inner {
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      gap: clamp(2rem, 5vw, 4rem);
    }

    .offers__row--alt .offers__inner {
      flex-direction: row-reverse;
    }

    .offers__label {
      flex: 0 0 auto;
    }
  }
</style>
