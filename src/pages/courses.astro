---
import BaseLayout from '../layouts/BaseLayout.astro';

const currentCourses = [
  'Лаборатория инноваций',
  'Деловые коммуникации',
  'Психология удачи',
  'Управление конфликтами и мотивирующая коммуникация',
  'Психология управления командами разработчиков',
  'Prospere: осознанное лидерство в твоей жизни',
  'Социальное влияние',
];

const readyCourses = [
  'Психология удачи лидера',
  'Мотивирующая коммуникация в жизни, отношениях, бизнесе',
];

const customDirections = [
  'Лидер инноваций',
  'Технологии современного мира',
  'Умение быть счастливым',
  'Лидер осознанного влияния',
];

const reviewCapabilities = [
  'Апгрейд готовых курсов до мировых трендов',
  'Анализ контента курсов на научную составляющую',
  'Удержание мотивации на обучающих платформах',
];
---

<BaseLayout
  title="Курсы: Абрамова Ольга"
  description="Курсы Ольги Абрамовой: готовые программы в НИУ ВШЭ, разработка курсов под бизнес, рецензия и пересборка существующих программ."
>
  <header class="courses-header">
    <h1 class="courses-header__heading reveal" style="--i:0">Курсы</h1>
    <p class="courses-header__lead reveal" style="--i:1">
      Около 20 курсов на стыке психологии, антропологии, IT и бизнеса: готовые программы,
      разработка под задачу и рецензия того, что у вас уже есть.
    </p>
  </header>

  <section class="course-block" aria-labelledby="current-heading">
    <div class="course-block__inner">
      <h2 id="current-heading" class="course-block__title reveal" style="--i:0">Курсы сейчас</h2>
      <ul class="course-block__list reveal" style="--i:1">
        {currentCourses.map((course) => <li>{course}</li>)}
      </ul>
      <p class="course-block__note reveal" style="--i:2">И ещё около 20 курсов в разработке и проведении.</p>
    </div>
  </section>

  <section class="course-block course-block--alt" aria-labelledby="ready-heading">
    <div class="course-block__inner">
      <h2 id="ready-heading" class="course-block__title reveal" style="--i:0">Мои курсы в НИУ ВШЭ</h2>
      <p class="course-block__lead reveal" style="--i:1">
        Начните обучение прямо сейчас. Каждое занятие: новая научно-обоснованная картина мира.
      </p>
      <ul class="course-block__list reveal" style="--i:2">
        {readyCourses.map((course) => <li>{course}</li>)}
      </ul>
    </div>
  </section>

  <section class="course-block" aria-labelledby="custom-heading">
    <div class="course-block__inner">
      <h2 id="custom-heading" class="course-block__title reveal" style="--i:0">Создание курсов и программ для бизнеса</h2>
      <p class="course-block__lead reveal" style="--i:1">Создадим уникальный научно-обоснованный курс для вас.</p>
      <ul class="course-block__tags reveal" style="--i:2">
        {customDirections.map((direction) => <li>{direction}</li>)}
      </ul>
    </div>
  </section>

  <section class="course-block course-block--alt" aria-labelledby="review-heading">
    <div class="course-block__inner">
      <h2 id="review-heading" class="course-block__title reveal" style="--i:0">Рецензия курсов и программ</h2>
      <p class="course-block__lead reveal" style="--i:1">
        Научный подход и современные тренды в каждом обучающем продукте вашей компании.
      </p>
      <ul class="course-block__list reveal" style="--i:2">
        {reviewCapabilities.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="courses-cta" aria-labelledby="courses-cta-heading">
    <div class="courses-cta__inner">
      <h2 id="courses-cta-heading" class="courses-cta__heading reveal" style="--i:0">Нужен курс под вашу задачу?</h2>
      <p class="courses-cta__lead reveal" style="--i:1">Напишите, что хотите обучить или пересобрать, обсудим формат.</p>
      <a class="courses-cta__link reveal" style="--i:2" href="https://t.me/OlgaAbr" target="_blank" rel="noopener noreferrer">
        Обсудить курс
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .courses-header {
    max-width: 64rem;
    margin: 0 auto;
    padding: clamp(2rem, 6vw, 3.5rem) clamp(1.25rem, 6vw, 5rem) clamp(2.5rem, 6vw, 4rem);
  }

  .courses-header__heading {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }

  .courses-header__lead {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    color: color-mix(in oklab, var(--color-ink) 78%, transparent);
    max-width: 55ch;
  }

  .course-block {
    background: var(--color-bg);
    padding: clamp(4rem, 9vw, 7rem) clamp(1.25rem, 6vw, 5rem);
  }

  .course-block--alt {
    background: var(--color-mist);
  }

  .course-block__inner {
    max-width: 64rem;
    margin: 0 auto;
  }

  .course-block__title {
    margin: 0 0 clamp(1rem, 3vw, 1.5rem);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(1.75rem, 4.5vw, 2.75rem);
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }

  .course-block__lead {
    margin: 0 0 clamp(1.5rem, 4vw, 2rem);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.0625rem, 2vw, 1.3125rem);
    color: var(--color-ink);
    max-width: 50ch;
  }

  .course-block__list {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid color-mix(in oklab, var(--color-ink) 18%, transparent);
  }

  .course-block__list li {
    padding: clamp(1rem, 2.5vw, 1.25rem) 0;
    border-bottom: 1px solid color-mix(in oklab, var(--color-ink) 18%, transparent);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.0625rem, 2vw, 1.3125rem);
    line-height: 1.3;
    color: var(--color-ink);
    max-width: 50ch;
  }

  .course-block__note {
    margin: clamp(1rem, 3vw, 1.5rem) 0 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.9375rem;
    color: color-mix(in oklab, var(--color-ink) 65%, transparent);
  }

  .course-block__tags {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .course-block__tags li {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-ink);
    background: color-mix(in oklab, var(--color-bg) 70%, transparent);
    padding: 0.55rem 1rem;
    border-radius: 2px;
  }

  .course-block--alt .course-block__tags li {
    background: color-mix(in oklab, var(--color-ink) 8%, var(--color-mist));
  }

  .courses-cta {
    background: var(--color-ink);
    padding: clamp(3.5rem, 9vw, 6rem) clamp(1.25rem, 6vw, 5rem);
  }

  .courses-cta__inner {
    max-width: 64rem;
    margin: 0 auto;
  }

  .courses-cta__heading {
    margin: 0 0 0.75rem;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(2rem, 5vw, 3.25rem);
    letter-spacing: -0.02em;
    color: var(--color-bg);
  }

  .courses-cta__lead {
    margin: 0 0 clamp(2rem, 5vw, 2.75rem);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    color: color-mix(in oklab, var(--color-bg) 82%, transparent);
    max-width: 50ch;
  }

  .courses-cta__link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.0625rem, 2vw, 1.25rem);
    color: var(--color-ink);
    background: var(--color-accent);
    padding: 1rem 1.75rem;
    border-radius: 2px;
    text-decoration: none;
    transition: transform 220ms var(--ease-out-quart);
  }

  .courses-cta__link span {
    transition: transform 220ms var(--ease-out-quart);
  }

  .courses-cta__link:hover,
  .courses-cta__link:focus-visible {
    transform: translateY(-2px);
  }

  .courses-cta__link:hover span,
  .courses-cta__link:focus-visible span {
    transform: translateX(3px);
  }

  .courses-cta__link:focus-visible {
    outline: 2px solid var(--color-bg);
    outline-offset: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .courses-cta__link,
    .courses-cta__link span {
      transition: none;
    }
  }
</style>
