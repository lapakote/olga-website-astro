---
import { Image } from 'astro:assets';
import business from '../assets/images/why-business.jpg';
import personal from '../assets/images/why-personal.jpg';
import media from '../assets/images/why-media.jpg';

const audienceCards = [
  {
    title: 'Бизнес-лидеры',
    description: 'Топ-менеджеры и собственники IT и бизнеса, которым нужен научный взгляд на стратегию.',
    image: business,
    width: 1333,
    height: 2000,
  },
  {
    title: 'Частные клиенты',
    description: 'Личный апгрейд: психология удачи, выход из кризиса, масштабирование мышления.',
    image: personal,
    width: 891,
    height: 1335,
  },
  {
    title: 'Организаторы и медиа',
    description: 'Конференции, форумы, медиа: для выступлений и экспертных комментариев.',
    image: media,
    width: 852,
    height: 1280,
  },
];

const rowOne = ['CEO', 'CTO', 'Основатель', 'HR-директор', 'Программный директор', 'Руководитель направления'];
const rowTwo = ['Спикер', 'Коуч', 'Исследователь', 'Консультант', 'Лектор', 'Модератор', 'Эксперт'];
---

<section class="why" id="why" aria-labelledby="why-heading">
  <div class="why__inner">
    <p class="why__label reveal" style="--i:0"><span aria-hidden="true">●</span> Почему именно так</p>

    <h2 id="why-heading" class="why__heading reveal" style="--i:1">
      <span class="why__heading-line">Глобальный взгляд</span>
      <span class="why__heading-line why__heading-line--accent">на каждый проект</span>
    </h2>

    <p class="why__description reveal" style="--i:2">
      Смотрю на каждый проект масштабно и стратегически, с учётом того, что происходит в науке, бизнесе и
      технологиях по всему миру. Участвую в крупных научных и коучинговых конференциях, поддерживаю
      международную сеть контактов и приношу в российские компании актуальные мировые практики.
    </p>

    <div class="why__cards">
      <figure class="why__card why__card--wide reveal" style="--i:3">
        <span class="img-zoom why__card-img-wrap">
          <video
            class="why__card-img why__card-video"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster="/images/why-wide-poster.jpg"
          >
            <source src="/video/why-wide.mp4" type="video/mp4" />
          </video>
        </span>
        <figcaption class="why__card-caption">Канд. псих. наук и PhD в организационной психологии: НИУ ВШЭ и ИЭА РАН</figcaption>
      </figure>

      {
        audienceCards.map((card, index) => (
          <article class="why__card reveal" style={`--i:${4 + index}`}>
            <span class="img-zoom why__card-img-wrap">
              <Image
                src={card.image}
                alt={card.title}
                width={card.width}
                height={card.height}
                loading="lazy"
                class="why__card-img"
                style={`aspect-ratio: ${card.width} / ${card.height}`}
              />
            </span>
            <div class="why__card-body">
              <h3 class="why__card-title">{card.title}</h3>
              <p class="why__card-text">{card.description}</p>
            </div>
            <span class="why__card-plus" aria-hidden="true">+</span>
          </article>
        ))
      }
    </div>

    <div class="why__banner reveal" style="--i:7">
      <div class="why__banner-text">
        <p>
          Если наука — часть вашей стратегии, <span class="why__banner-accent">это направление для вас.</span>
        </p>
        <a class="why__banner-btn" href="#offers">Смотреть направления</a>
      </div>

      <div class="why__marquee" aria-hidden="true">
        <div class="why__marquee-row">
          {Array.from({ length: 2 }).map(() => rowOne.map((title) => <span>{title}</span>))}
        </div>
        <div class="why__marquee-row why__marquee-row--reverse">
          {Array.from({ length: 2 }).map(() => rowTwo.map((title) => <span>{title}</span>))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const video = document.querySelector<HTMLVideoElement>('.why__card-video');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  function syncMotionPreference() {
    if (!video) return;
    if (prefersReducedMotion.matches) {
      video.removeAttribute('autoplay');
      video.pause();
    } else {
      video.play().catch(() => {});
    }
  }

  syncMotionPreference();
  prefersReducedMotion.addEventListener('change', syncMotionPreference);

  if (video && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (prefersReducedMotion.matches) continue;
          if (entry.isIntersecting) video.play().catch(() => {});
          else video.pause();
        }
      },
      { threshold: 0.2 }
    );
    observer.observe(video);
  }
</script>

<style>
  .why {
    background: var(--bg-base);
    padding: clamp(5rem, 12vw, 9rem) 0 clamp(4rem, 9vw, 6rem);
  }

  .why__inner {
    max-width: 84rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 6vw, 5rem);
  }

  .why__label {
    margin: 0 0 clamp(2rem, 5vw, 3rem);
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--ink);
  }

  .why__label span {
    color: var(--accent-deep);
    font-size: 0.6rem;
  }

  .why__heading {
    margin: 0 0 clamp(1.5rem, 4vw, 2.25rem);
    display: flex;
    flex-direction: column;
  }

  .why__heading-line {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.25rem, 6.5vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .why__heading-line--accent {
    color: var(--accent-deep);
  }

  .why__description {
    margin: 0 0 clamp(3rem, 7vw, 4.5rem);
    max-width: 55ch;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink-soft);
  }

  .why__cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: clamp(3rem, 7vw, 4.5rem);
  }

  .why__card {
    position: relative;
    margin: 0;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }

  .why__card-img-wrap {
    width: 100%;
  }

  .why__card-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .why__card--wide {
    position: relative;
  }

  .why__card--wide .why__card-img {
    aspect-ratio: 16 / 9;
  }

  .why__card-caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 1.25rem 1.5rem;
    background: linear-gradient(180deg, transparent, rgba(246, 244, 238, 0.95) 70%);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--ink);
  }

  .why__card-body {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .why__card-title {
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.25rem;
    color: var(--ink);
  }

  .why__card-text {
    margin: 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--ink-soft);
  }

  .why__card-plus {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    font-family: var(--font-body);
    font-size: 1.25rem;
    color: var(--ink-faint);
  }

  /* Deliberate dark contrast block amid the light page, same role the main
     site's ink slabs play. Bright accent reads fine here since the backdrop
     is dark. */
  .why__banner {
    background: var(--ink);
    border-radius: 16px;
    padding: clamp(1.75rem, 4vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 4vw, 2rem);
  }

  .why__banner-text p {
    margin: 0 0 1.25rem;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(1.0625rem, 2.2vw, 1.375rem);
    color: var(--on-dark);
    max-width: 28ch;
  }

  .why__banner-accent {
    color: var(--accent);
  }

  .why__banner-btn {
    display: inline-flex;
    align-items: center;
    height: 2.875rem;
    padding: 0 1.75rem;
    border-radius: 999px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--on-dark);
    text-decoration: none;
    background: linear-gradient(55deg, var(--sky-1) 0%, var(--sky-2) 100%);
    transition: filter 220ms var(--ease-out-quart);
  }

  .why__banner-btn:hover,
  .why__banner-btn:focus-visible {
    filter: brightness(1.1);
  }

  .why__marquee {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    overflow: hidden;
  }

  .why__marquee-row {
    display: flex;
    gap: 0.625rem;
    width: max-content;
    animation: marquee-scroll 28s linear infinite;
  }

  .why__marquee-row--reverse {
    animation-direction: reverse;
  }

  .why__marquee-row span {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.8125rem;
    color: var(--on-dark);
    background: rgba(255, 255, 255, 0.1);
    padding: 0.5rem 1rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  @keyframes marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .why__marquee-row {
      animation: none;
    }

    .why__banner-btn {
      transition: none;
    }
  }

  @media (min-width: 720px) {
    .why__cards {
      grid-template-columns: repeat(2, 1fr);
    }

    .why__card--wide {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1024px) {
    .why__cards {
      grid-template-columns: repeat(3, 1fr);
    }

    /* The wide card stays a real landscape banner at every breakpoint —
       forcing its 4:3 source into a tall portrait column here used to crop
       out most of the photo. Spanning full width keeps the crop gentle
       (top/bottom only) instead of severe (both sides). */
    .why__card--wide {
      grid-column: 1 / -1;
    }

    .why__banner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .why__banner-text p {
      margin-bottom: 0;
    }

    .why__banner-text {
      display: flex;
      align-items: center;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .why__marquee {
      width: 22rem;
    }
  }
</style>
