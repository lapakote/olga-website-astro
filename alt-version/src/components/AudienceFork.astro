---
// Repurposes the original's "Become a Sponsor" slot: there's no sponsorship
// program here, so this is the site's real audience fork instead — the same
// Бизнесу / Для себя split used on the main site, pointing at those real pages.
const tracks = [
  {
    title: 'Бизнесу',
    description: 'Наука как конкурентное преимущество компании: выступления, курсы, консалтинг и эдвайзинг.',
    items: ['Спикерство', 'Курсы для бизнеса', 'Консалтинг и научный эдвайзинг', 'Мероприятия'],
    href: '/business',
  },
  {
    title: 'Для себя',
    description: 'Личный апгрейд: курсы, авторская колонка, life-коучинг и психология удачи.',
    items: ['Курсы ДПО ВШЭ', 'Авторский курс Ольги', 'Статьи на IQ Media', 'Life-коучинг'],
    href: '/personal',
  },
];
---

<section class="fork" aria-labelledby="fork-heading">
  <div class="fork__inner">
    <p class="fork__label reveal" style="--i:0"><span aria-hidden="true">●</span> Кому подходит</p>
    <h2 id="fork-heading" class="fork__heading reveal" style="--i:1">Выберите свой путь</h2>

    <div class="fork__grid">
      {
        tracks.map((track, index) => (
          <a class="fork__card reveal" style={`--i:${2 + index}`} href={track.href}>
            <div class="fork__card-top">
              <h3 class="fork__card-title">{track.title}</h3>
              <span class="fork__card-arrow" aria-hidden="true">→</span>
            </div>
            <p class="fork__card-text">{track.description}</p>
            <ul class="fork__card-list">
              {track.items.map((item) => <li>{item}</li>)}
            </ul>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .fork {
    background: var(--ink);
    padding: clamp(5rem, 12vw, 9rem) 0;
  }

  .fork__inner {
    max-width: 84rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 6vw, 5rem);
  }

  .fork__label {
    margin: 0 0 clamp(2rem, 5vw, 3rem);
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--on-dark);
  }

  .fork__label span {
    color: var(--accent);
    font-size: 0.6rem;
  }

  .fork__heading {
    margin: 0 0 clamp(2.5rem, 6vw, 3.5rem);
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.25rem, 6.5vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--on-dark);
  }

  .fork__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .fork__card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1.75rem, 4vw, 2.5rem);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    text-decoration: none;
    color: inherit;
    transition: background-color 220ms var(--ease-out-quart), border-color 220ms var(--ease-out-quart);
  }

  .fork__card:hover,
  .fork__card:focus-visible {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--accent);
  }

  .fork__card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .fork__card-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--on-dark);
  }

  .fork__card-arrow {
    font-size: 1.5rem;
    color: var(--accent);
    transition: transform 220ms var(--ease-out-quart);
  }

  .fork__card:hover .fork__card-arrow,
  .fork__card:focus-visible .fork__card-arrow {
    transform: translateX(4px);
  }

  .fork__card-text {
    margin: 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--on-dark-soft);
    max-width: 40ch;
  }

  .fork__card-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .fork__card-list li {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.8125rem;
    color: var(--on-dark);
    background: rgba(255, 255, 255, 0.1);
    padding: 0.4rem 0.875rem;
    border-radius: 999px;
  }

  @media (prefers-reduced-motion: reduce) {
    .fork__card,
    .fork__card-arrow {
      transition: none;
    }
  }

  @media (min-width: 720px) {
    .fork__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
