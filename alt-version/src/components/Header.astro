---
const navLinks = [
  { href: '/#about', label: 'Обо мне' },
  { href: '/#offers', label: 'Направления' },
  { href: '/#topics', label: 'Темы' },
  { href: '/#events', label: 'Мероприятия' },
  { href: '/#contact', label: 'Связаться' },
];
---

<header class="header">
  <div class="header__bar">
    <a href="/" class="header__logo">Абрамова</a>
    <nav class="header__nav" aria-label="Основная навигация">
      {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('.header');

  function syncScrolledState() {
    if (!header) return;
    header.classList.toggle('header--scrolled', window.scrollY > 64);
  }

  syncScrolledState();
  window.addEventListener('scroll', syncScrolledState, { passive: true });
</script>

<style>
  /* Transparent over the hero video, the way the original reference does —
     but once the page scrolls past it, light sections would swallow the
     white text entirely, so .header--scrolled (toggled in the script above)
     switches to a solid surface with dark text. */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    transition: background-color 220ms var(--ease-out-quart), box-shadow 220ms var(--ease-out-quart);
  }

  .header--scrolled {
    background-color: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(10px);
    box-shadow: 0 1px 0 var(--border);
  }

  .header--scrolled .header__logo,
  .header--scrolled .header__nav a {
    color: var(--ink);
    text-shadow: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .header {
      transition: none;
    }
  }

  .header__bar {
    max-width: 84rem;
    margin: 0 auto;
    padding: 1.25rem clamp(1.25rem, 6vw, 5rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  /* Same wordmark treatment as the footer's giant background mark, just at
     header scale and full opacity so it reads as a logo, not a decoration. */
  .header__logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.125rem, 2vw, 1.3125rem);
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--on-dark);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.45);
    text-decoration: none;
    white-space: nowrap;
  }

  .header__nav {
    display: none;
    align-items: center;
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }

  .header__nav a {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--on-dark);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.45);
    text-decoration: none;
    opacity: 0.92;
    transition: opacity 180ms var(--ease-out-quart);
  }

  .header__nav a:hover,
  .header__nav a:focus-visible {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .header__nav a {
      transition: none;
    }
  }

  @media (min-width: 880px) {
    .header__nav {
      display: flex;
    }
  }
</style>
