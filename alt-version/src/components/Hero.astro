---
const stats = [
  { value: '4', label: 'языка' },
  { value: '20+', label: 'авторских курсов' },
  { value: '1000', label: 'студентов в год' },
  { value: '12', label: 'лет в консалтинге' },
];
---

<section class="hero" id="top" aria-label="Абрамова Ольга, социальный психолог и антрополог">
  <video class="hero__video" autoplay muted loop playsinline preload="auto" poster="/images/hero-poster.jpg">
    <source src="/video/hero-intro.mp4" type="video/mp4" />
  </video>
  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="hero__top">
    <h1 class="hero__name reveal" style="--i:0">
      <span class="hero__name-line hero__name-line--accent">Абрамова Ольга</span>
      <span class="hero__name-line">Социальный психолог и антрополог</span>
    </h1>

    <p class="hero__credentials reveal" style="--i:1">Канд. псих. наук, PhD в организационной психологии</p>

    <dl class="hero__stats reveal" style="--i:2">
      {
        stats.map((stat) => (
          <div class="hero__stat">
            <dt>{stat.value}</dt>
            <dd>{stat.label}</dd>
          </div>
        ))
      }
    </dl>
  </div>

  <div class="hero__bottom reveal" style="--i:2">
    <div class="hero__meta">
      <div class="hero__meta-item">
        <span class="hero__meta-label">Специализация</span>
        <span class="hero__meta-value">ИТ, инновационное лидерство, психология удачи</span>
      </div>
      <div class="hero__meta-item">
        <span class="hero__meta-label">Формат</span>
        <span class="hero__meta-value">Спикерство · консалтинг · коучинг</span>
      </div>
    </div>

    <div class="hero__actions">
      <a class="hero__btn hero__btn--ghost" href="#offers">Направления</a>
      <a class="hero__btn hero__btn--filled" href="https://t.me/OlgaAbr" target="_blank" rel="noopener noreferrer">
        Написать
      </a>
    </div>
  </div>
</section>

<script>
  const video = document.querySelector<HTMLVideoElement>('.hero__video');
  const hero = document.querySelector<HTMLElement>('.hero');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  function syncMotionPreference() {
    if (!video) return;
    if (prefersReducedMotion.matches) {
      video.removeAttribute('autoplay');
      video.pause();
      video.currentTime = 0;
    } else {
      video.play().catch(() => {});
    }
  }

  syncMotionPreference();
  prefersReducedMotion.addEventListener('change', syncMotionPreference);

  if (video && hero && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (prefersReducedMotion.matches) continue;
          if (entry.isIntersecting) video.play().catch(() => {});
          else video.pause();
        }
      },
      { threshold: 0.1 }
    );
    observer.observe(hero);
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    width: 100%;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    isolation: isolate;
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 14%;
    z-index: var(--z-base);
  }

  /* A light veil, not a color filter: keeps the footage's real colors recognizable
     (faces, skin tone) while giving the dark ink text enough contrast everywhere
     on the hero, not just where the footage happens to be dark. */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: var(--z-scrim);
    background: linear-gradient(
      180deg,
      rgba(246, 244, 238, 0.6) 0%,
      rgba(246, 244, 238, 0.32) 35%,
      rgba(246, 244, 238, 0.45) 65%,
      rgba(246, 244, 238, 0.7) 100%
    );
    pointer-events: none;
  }

  .hero__top {
    position: relative;
    z-index: var(--z-content);
    padding: clamp(7rem, 16vw, 10rem) clamp(1.25rem, 6vw, 5rem) 0;
  }

  .hero__name {
    margin: 0 0 clamp(2.5rem, 6vw, 4rem);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .hero__name-line {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.5rem, 8vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .hero__name-line--accent {
    color: var(--accent-deep);
  }

  .hero__credentials {
    margin: 0 0 clamp(2rem, 5vw, 3rem);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: clamp(0.9375rem, 1.6vw, 1.0625rem);
    color: var(--ink);
  }

  .hero__stats {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.5rem, 4vw, 2.5rem);
    max-width: 44rem;
  }

  .hero__stat dt {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1;
    color: var(--ink);
  }

  .hero__stat dd {
    margin: 0.375rem 0 0;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--ink-soft);
  }

  .hero__bottom {
    position: relative;
    z-index: var(--z-content);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(0.75rem, 1.8vw, 1.125rem) clamp(1.25rem, 6vw, 5rem);
    background: rgba(246, 244, 238, 0.82);
    border-top: 1px solid var(--border);
  }

  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.5rem, 4vw, 3rem);
  }

  .hero__meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .hero__meta-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.8125rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .hero__meta-value {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: clamp(1rem, 1.6vw, 1.125rem);
    color: var(--accent-deep);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    text-decoration: none;
    height: 2.5rem;
    padding: 0 1.5rem;
    border-radius: 999px;
    transition: background-color 220ms var(--ease-out-quart), color 220ms var(--ease-out-quart),
      border-color 220ms var(--ease-out-quart);
  }

  .hero__btn--ghost {
    color: var(--ink);
    background: transparent;
    box-shadow: inset 0 0 0 1.5px rgba(27, 27, 22, 0.35);
  }

  .hero__btn--ghost:hover,
  .hero__btn--ghost:focus-visible {
    box-shadow: inset 0 0 0 1.5px var(--accent-deep);
    color: var(--accent-deep);
  }

  .hero__btn--filled {
    color: var(--ink);
    background: var(--accent);
  }

  .hero__btn--filled:hover,
  .hero__btn--filled:focus-visible {
    background: var(--ink);
    color: var(--bg-base);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__btn {
      transition: none;
    }
  }

  @media (min-width: 720px) {
    .hero__stats {
      grid-template-columns: repeat(4, auto);
    }
  }

  @media (min-width: 880px) {
    .hero__bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
</style>
