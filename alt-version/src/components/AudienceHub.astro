---
import { Image } from 'astro:assets';

interface Item {
  title: string;
  description: string;
  href?: string;
  external?: boolean;
  badge?: string;
}

interface Props {
  heading: string;
  lead: string;
  items: Item[];
  portrait: ImageMetadata;
  portraitWidth: number;
  portraitHeight: number;
}

const { heading, lead, items, portrait, portraitWidth, portraitHeight } = Astro.props;
---

<section class="audience-hub" aria-labelledby="audience-hub-heading">
  <div class="audience-hub__top">
    <div class="audience-hub__top-text">
      <h1 id="audience-hub-heading" class="audience-hub__heading reveal" style="--i:0">{heading}</h1>
      <p class="audience-hub__lead reveal" style="--i:1">{lead}</p>
    </div>
    <figure class="audience-hub__portrait reveal" style={`--i:1; aspect-ratio: ${portraitWidth} / ${portraitHeight}`}>
      <Image src={portrait} alt="Ольга Абрамова" width={portraitWidth} height={portraitHeight} loading="lazy" />
    </figure>
  </div>

  <div class="audience-hub__inner">
    <ul class="audience-hub__list">
      {
        items.map((item, index) => {
          const Tag = item.href ? 'a' : 'div';
          const linkProps = item.href
            ? { href: item.href, ...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}) }
            : {};
          return (
            <li class="audience-hub__item reveal" style={`--i:${index + 2}`}>
              <Tag class="audience-hub__item-inner" {...linkProps}>
                <div class="audience-hub__item-text">
                  <p class="audience-hub__item-title">
                    {item.title}
                    {item.badge && <span class="audience-hub__badge">{item.badge}</span>}
                  </p>
                  <p class="audience-hub__item-description">{item.description}</p>
                </div>
                {item.href && (
                  <span class="audience-hub__arrow" aria-hidden="true">
                    {item.external ? '↗' : '→'}
                  </span>
                )}
              </Tag>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<style>
  .audience-hub {
    background: var(--bg-base);
    padding: clamp(3.5rem, 9vw, 6rem) 0 clamp(5.5rem, 12vw, 9rem);
  }

  .audience-hub__inner {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 6vw, 5rem);
  }

  .audience-hub__top {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 4vw, 2.5rem);
    margin-bottom: clamp(3.5rem, 8vw, 5.5rem);
  }

  .audience-hub__top-text {
    padding: 0 clamp(1.25rem, 6vw, 5rem);
  }

  .audience-hub__heading {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .audience-hub__lead {
    margin: 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    color: var(--ink-soft);
    max-width: 50ch;
  }

  .audience-hub__portrait {
    margin: 0;
    width: 100%;
    overflow: hidden;
    border-radius: 16px;
  }

  .audience-hub__portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .audience-hub__list {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--border);
  }

  .audience-hub__item {
    border-bottom: 1px solid var(--border);
  }

  .audience-hub__item-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: clamp(1.25rem, 3vw, 1.75rem) 0;
    text-decoration: none;
    color: inherit;
  }

  a.audience-hub__item-inner {
    transition: padding-left 220ms var(--ease-out-quart);
  }

  a.audience-hub__item-inner:hover,
  a.audience-hub__item-inner:focus-visible {
    padding-left: 0.5rem;
  }

  .audience-hub__item-text {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .audience-hub__item-title {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.125rem, 2.2vw, 1.375rem);
    color: var(--ink);
  }

  .audience-hub__badge {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.75rem;
    color: var(--accent-deep);
    border: 1px solid var(--accent-deep);
    border-radius: 999px;
    padding: 0.1rem 0.625rem;
  }

  .audience-hub__item-description {
    margin: 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.9375rem;
    color: var(--ink-soft);
    max-width: 50ch;
  }

  .audience-hub__arrow {
    flex: 0 0 auto;
    font-size: 1.25rem;
    color: var(--ink);
    transition: color 220ms var(--ease-out-quart), transform 220ms var(--ease-out-quart);
  }

  a.audience-hub__item-inner:hover .audience-hub__arrow,
  a.audience-hub__item-inner:focus-visible .audience-hub__arrow {
    color: var(--accent-deep);
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    a.audience-hub__item-inner,
    .audience-hub__arrow {
      transition: none;
    }
  }

  @media (min-width: 700px) {
    .audience-hub__top {
      flex-direction: row;
      align-items: stretch;
    }

    .audience-hub__top-text {
      flex: 1 1 auto;
      padding-right: clamp(1.5rem, 4vw, 3rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .audience-hub__portrait {
      flex: 0 0 auto;
      width: auto;
      height: clamp(16rem, 28vw, 22rem);
    }
  }
</style>
