---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import AboutMe from '../components/AboutMe.astro';
import WhyDifferent from '../components/WhyDifferent.astro';
import Directions from '../components/Directions.astro';
import TopicsSlider from '../components/TopicsSlider.astro';
import AudienceFork from '../components/AudienceFork.astro';
import Partners from '../components/Partners.astro';
import PreviousEvents from '../components/PreviousEvents.astro';
import Faq from '../components/Faq.astro';
