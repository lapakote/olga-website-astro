---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const upgradeFeatures = ['Выход из иллюзий', 'Готовые отработанные программы', 'Стабильный результат'];

const businessFeatures = [
  'Личное сопровождение руководителей и собственников',
  'Цифровая трансформация и реструктуризация',
  'Сопровождение при кадровых изменениях',
];
---

<BaseLayout
  title="Коучинг: Абрамова Ольга"
  description="Коучинг Ольги Абрамовой: программа Upgrade, бизнес-коучинг, психология удачи, выход из кризиса. Метод научного скаффолдинга."
>
  <Header />

  <header class="page-header">
    <p class="page-header__label reveal" style="--i:0"><span aria-hidden="true">●</span> Направления</p>
    <h1 class="page-header__heading reveal" style="--i:1">Коучинг</h1>
    <p class="page-header__lead reveal" style="--i:2">
      Метод научного скаффолдинга соединяет обучение научной базе, психологическое консультирование, рефлексивные
      методики и практики осознанности.
    </p>
  </header>

  <section class="program" aria-labelledby="upgrade-heading">
    <div class="program__inner">
      <p class="program__kicker reveal" style="--i:0">Life-коучинг</p>
      <h2 id="upgrade-heading" class="program__title reveal" style="--i:1">Программа Upgrade</h2>
      <p class="program__lead reveal" style="--i:2">Ваш личный апгрейд на научной базе за 8–10 сессий.</p>
      <ul class="program__list reveal" style="--i:3">
        {upgradeFeatures.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="program program--alt" aria-labelledby="business-heading">
    <div class="program__inner">
      <p class="program__kicker reveal" style="--i:0">Бизнес-коучинг</p>
      <h2 id="business-heading" class="program__title reveal" style="--i:1">Коучинг нового поколения</h2>
      <ul class="program__list reveal" style="--i:2">
        {businessFeatures.map((item) => <li>{item}</li>)}
      </ul>
      <p class="program__note reveal" style="--i:3">Программы бизнес-коучинга высылаются по запросу.</p>
      <p class="program__example reveal" style="--i:4">Пример программы: «Масштабирование мышления = масштабирование бизнеса».</p>
    </div>
  </section>

  <section class="program" aria-labelledby="luck-heading">
    <div class="program__inner">
      <p class="program__kicker reveal" style="--i:0">Программа</p>
      <h2 id="luck-heading" class="program__title reveal" style="--i:1">Психология удачи</h2>
    </div>
  </section>

  <section class="program program--alt" aria-labelledby="crisis-heading">
    <div class="program__inner">
      <p class="program__kicker reveal" style="--i:0">Программа</p>
      <h2 id="crisis-heading" class="program__title reveal" style="--i:1">Выход из кризиса</h2>
      <p class="program__lead reveal" style="--i:2">Создадим баланс контроля и гибкости в жизни.</p>
      <p class="program__note reveal" style="--i:3">Выйдем из кризиса без потери времени и без ошибочных решений.</p>
    </div>
  </section>

  <section class="page-cta">
    <div class="page-cta__inner">
      <h2 class="page-cta__heading reveal" style="--i:0">Какая программа откликается?</h2>
      <p class="page-cta__lead reveal" style="--i:1">Напишите, что сейчас важно: разберём формат и сроки.</p>
      <a class="page-cta__link reveal" style="--i:2" href="https://t.me/OlgaAbr" target="_blank" rel="noopener noreferrer">
        Обсудить коучинг
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .page-header {
    max-width: 64rem;
    margin: 0 auto;
    padding: clamp(7rem, 14vw, 10rem) clamp(1.25rem, 6vw, 5rem) clamp(2.5rem, 6vw, 4rem);
  }

  .page-header__label {
    margin: 0 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--ink);
  }

  .page-header__label span {
    color: var(--accent-deep);
    font-size: 0.6rem;
  }

  .page-header__heading {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .page-header__lead {
    margin: 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    color: var(--ink-soft);
    max-width: 55ch;
  }

  .program {
    background: var(--bg-base);
    padding: clamp(4rem, 9vw, 7rem) clamp(1.25rem, 6vw, 5rem);
  }

  .program--alt {
    background: var(--bg-alt);
  }

  .program__inner {
    max-width: 64rem;
    margin: 0 auto;
  }

  .program__kicker {
    margin: 0 0 0.5rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--accent-deep);
  }

  .program__title {
    margin: 0 0 clamp(1rem, 3vw, 1.5rem);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .program__lead {
    margin: 0 0 clamp(1.25rem, 3vw, 1.75rem);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(1.0625rem, 2vw, 1.3125rem);
    color: var(--ink);
    max-width: 50ch;
  }

  .program__list {
    margin: 0 0 clamp(1.25rem, 3vw, 1.5rem);
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--border);
  }

  .program__list li {
    padding: clamp(0.875rem, 2vw, 1.1rem) 0;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(0.9375rem, 1.6vw, 1.0625rem);
    color: var(--ink-soft);
    max-width: 50ch;
  }

  .program__note {
    margin: 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.9375rem;
    color: var(--ink-faint);
  }

  .program__example {
    margin: 0.5rem 0 0;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--ink);
  }

  .page-cta {
    background: var(--ink);
    padding: clamp(3.5rem, 9vw, 6rem) clamp(1.25rem, 6vw, 5rem);
  }

  .page-cta__inner {
    max-width: 64rem;
    margin: 0 auto;
  }

  .page-cta__heading {
    margin: 0 0 0.75rem;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: -0.02em;
    color: var(--on-dark);
  }

  .page-cta__lead {
    margin: 0 0 clamp(2rem, 5vw, 2.75rem);
    font-family: var(--font-body);
    font-weight: 400;
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    color: var(--on-dark-soft);
    max-width: 50ch;
  }

  .page-cta__link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--ink);
    background: var(--accent);
    padding: 0.875rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    transition: transform 220ms var(--ease-out-quart);
  }

  .page-cta__link span {
    transition: transform 220ms var(--ease-out-quart);
  }

  .page-cta__link:hover,
  .page-cta__link:focus-visible {
    transform: translateY(-2px);
  }

  .page-cta__link:hover span,
  .page-cta__link:focus-visible span {
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .page-cta__link,
    .page-cta__link span {
      transition: none;
    }
  }
</style>
